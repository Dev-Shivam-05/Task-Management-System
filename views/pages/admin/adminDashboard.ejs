                            <button class="action-btn" title="View"><i class="bi bi-eye"></i></button>
                            <button class="action-btn" title="Edit"><i class="bi bi-pencil"></i></button>
                            <button class="action-btn danger" title="Delete"><i class="bi bi-trash"></i></button>
                        </div>
