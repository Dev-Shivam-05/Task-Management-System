            const tbody = document.getElementById('tasksTableBody');
            tbody.innerHTML = '';

            tasks.forEach(task => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>
                        <div style="font-weight: 500; font-size: 0.95rem;">${task.title}</div>
                        <small style="color: rgba(255,255,255,0.6);">#TASK-${task.id.toString().padStart(4, '0')}</small>
                    </td>
                    <td>
                        <div class="user-cell">
                            <div class="avatar">${task.assignee.charAt(0)}</div>
                            <div class="user-info">
                                <span class="name">${task.assignee}</span>
                                <span class="email">${task.email}</span>
                            </div>
                        </div>
                    </td>
                    <td><span style="color: rgba(255,255,255,0.85);">${task.category}</span></td>
                    <td class="progress-cell">
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <div class="progress-bar-glass">
                                <div class="progress-fill" style="width: ${task.progress}%"></div>
                            </div>
                            <small style="color: rgba(255,255,255,0.85); font-weight: 500;">${task.progress}%</small>
                        </div>
                    </td>
                    <td><span style="color: ${task.status === 'overdue' ? '#f45c43' : 'rgba(255,255,255,0.85)'}">${task.due}</span></td>
                    <td><span class="status-badge ${task.status}"><i class="bi bi-${task.status === 'completed' ? 'check-circle' : task.status === 'in-progress' ? 'clock' : task.status === 'pending' ? 'hourglass-split' : 'exclamation-circle'}"></i> ${task.status.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase())}</span></td>
                    <td>
