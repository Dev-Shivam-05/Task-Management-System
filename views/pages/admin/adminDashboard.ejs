        // ===== EVENT LISTENERS =====
        function setupEventListeners() {
            // Sidebar toggle for mobile
            document.getElementById('sidebarToggle')?.addEventListener('click', function () {
                document.querySelector('.sidebar').classList.toggle('show');
            });

            // Chart period buttons
            document.querySelectorAll('.chart-actions .chart-btn').forEach(btn => {
                btn.addEventListener('click', function () {
                    this.parentElement.querySelectorAll('.chart-btn').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    showToast(`Showing data for: ${this.textContent}`, 'info');
                });
            });

            // Global search
            document.getElementById('globalSearch')?.addEventListener('input', function (e) {
                const query = e.target.value.toLowerCase();
                // In real app: filter table data here
                if (query.length > 2) {
                    showToast(`Searching for: "${query}"`, 'info');
                }
            });

            // Table row click
            document.getElementById('tasksTableBody')?.addEventListener('click', function (e) {
                const row = e.target.closest('tr');
                if (row && !e.target.closest('.action-btn')) {
                    const taskId = row.querySelector('small').textContent;
                    showToast(`Viewing details for ${taskId}`, 'info');
                }
            });
        }

        // ===== TOAST NOTIFICATION SYSTEM (Enhanced) =====
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');

            const icons = {
                success: 'check-circle-fill',
                error: 'x-circle-fill',
                warning: 'exclamation-triangle-fill',
                info: 'info-circle-fill'
            };

            const bgClass = {
                success: 'bg-success',
                error: 'bg-danger',
                warning: 'bg-warning text-dark',
                info: 'bg-white'
            };

            toast.className = `toast toast-animated align-items-center border-0 shadow-lg mb-2 ${bgClass[type] || 'bg-white'}`;
            toast.setAttribute('role', 'alert');
            toast.innerHTML = `
                <div class="d-flex w-100">
                    <div class="toast-body d-flex align-items-center gap-2 flex-grow-1">
                        <i class="bi bi-${icons[type] || icons.info}"></i>
                        <span class="small fw-medium">${message}</span>
                    </div>
                    <button type="button" class="btn-close ${type === 'warning' ? '' : 'btn-close-white'} me-2" data-bs-dismiss="toast"></button>
                </div>
            `;

            container.appendChild(toast);

            // Auto-dismiss
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(20px)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);

            // Manual dismiss
            toast.querySelector('.btn-close').addEventListener('click', () => {
                toast.remove();
            });
        }

        // ===== EXPORT FUNCTIONALITY =====
        function exportData() {
            showToast('Preparing export...', 'info');
            setTimeout(() => {
                showToast('Report exported successfully! 📊', 'success');
            }, 1500);
        }

        // ===== REAL-TIME UPDATES SIMULATION =====
        setInterval(() => {
            // Simulate real-time activity
            const activities = [
                { msg: 'New task assigned to team', type: 'info' },
                { msg: 'User completed onboarding', type: 'success' },
                { msg: 'System backup completed', type: 'success' },
                { msg: 'Pending approval required', type: 'warning' }
            ];

            // Randomly show notification (20% chance)
            if (Math.random() < 0.2) {
                const activity = activities[Math.floor(Math.random() * activities.length)];
                showToast(activity.msg, activity.type);
            }

            // Update timestamp
            document.getElementById('lastUpdated').textContent = new Date().toLocaleTimeString();
        }, 30000);
    </script>
