        // ===== TASKS TABLE POPULATION =====
        function loadTasksTable() {
            const tasks = [
                { id: 1, title: 'API Integration Module', assignee: 'Sarah Chen', email: 'sarah@company.com', category: 'Development', progress: 95, due: 'Today', status: 'completed' },
                { id: 2, title: 'User Dashboard Redesign', assignee: 'Miguel Rodriguez', email: 'miguel@company.com', category: 'Design', progress: 78, due: 'Tomorrow', status: 'in-progress' },
                { id: 3, title: 'Database Optimization', assignee: 'Alex Thompson', email: 'alex@company.com', category: 'DevOps', progress: 45, due: 'Dec 28', status: 'in-progress' },
                { id: 4, title: 'Marketing Campaign Q4', assignee: 'Emma Wilson', email: 'emma@company.com', category: 'Marketing', progress: 20, due: 'Dec 30', status: 'pending' },
                { id: 5, title: 'Security Audit Report', assignee: 'David Kim', email: 'david@company.com', category: 'QA', progress: 10, due: 'Jan 5', status: 'pending' },
                { id: 6, title: 'Mobile App Bug Fixes', assignee: 'Lisa Park', email: 'lisa@company.com', category: 'Development', progress: 0, due: 'Dec 25', status: 'overdue' }
