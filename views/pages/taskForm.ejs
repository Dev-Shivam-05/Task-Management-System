<!-- taskForm.ejs -->
<!-- Designed as a 'Glass Command Bar' to fit the Dark/Premium Theme -->

<div class="glass-command-bar p-2 mb-4" data-aos="fade-down" data-aos-duration="600">
    <form action="/tasks" method="POST" class="row g-0 align-items-center">

        <!-- Task Title Input -->
         <!-- silightly adjust the width of the input field -->
        <div class="col-lg-3 col-md-12 mb-2 mb-lg-0 pe-lg-2">
            <div class="input-group-custom">
                <i class="bi bi-pencil-square input-icon-left"></i>
                <input type="text" class="form-control glass-input" name="title" placeholder="What needs to be done?"
                    required autocomplete="off">
            </div>
        </div>


        <!-- User Select -->
        <div class="col-lg-2 col-md-6 mb-2 mb-lg-0 px-lg-2">
            <div class="input-group-custom">
                <i class="bi bi-tag input-icon-left"></i>
                <select name="assignee" class="form-select glass-input" required>
                    <option value="" disabled selected>Select User</option>
                    <% if (typeof users !=='undefined' && users.length> 0) { %>
                        <% users.forEach(user=> { %>
                            <option value="<%= user._id %>">
                                <%= user.username %>
                            </option>
                            <% }) %>
                                <% } else { %>
                                    <option value="" disabled>No Users Found</option>
                                    <% } %>
                </select>
            </div>
        </div>
        
        <!-- Category Select -->
        <div class="col-lg-3 col-md-6 mb-2 mb-lg-0 px-lg-2">
            <div class="input-group-custom">
                <i class="bi bi-tag input-icon-left"></i>
                <select name="category" class="form-select glass-input" required>
                    <option value="" disabled selected>Select Category</option>
                    <% if (typeof categories !=='undefined' && categories.length> 0) { %>
                        <% categories.forEach(category=> { %>
                            <option value="<%= category._id %>">
                                <%= category.name %>
                            </option>
                            <% }) %>
                                <% } else { %>
                                    <option value="" disabled>No Categories Found</option>
                                    <% } %>
                </select>
            </div>
        </div>

        <!-- Status Select (Hidden on small mobile to save space, or kept if crucial) -->
        <div class="col-lg-2 col-md-6 mb-2 mb-lg-0 px-lg-2">
            <div class="input-group-custom">
                <i class="bi bi-check-circle input-icon-left"></i>
                <select name="status" class="form-select glass-input">
                    <option value="pending">Pending</option>
                    <option value="completed">Completed</option>
                </select>
            </div>
        </div>

        <!-- Submit Button -->
        <div class="col-lg-2 col-md-12 ps-lg-2">
            <button type="submit"
                class="btn btn-gradient-add w-100 d-flex align-items-center justify-content-center gap-2">
                <i class="bi bi-plus-lg"></i>
                <span>Add Task</span>
            </button>
        </div>

    </form>
</div>

<style>
    /* Container for the form - Glassmorphism Bar */
    .glass-command-bar {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    }

    /* Custom Input Wrapper for Icon Positioning */
    .input-group-custom {
        position: relative;
        width: 100%;
    }

    .input-icon-left {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255, 255, 255, 0.5);
        z-index: 5;
        transition: color 0.3s ease;
        pointer-events: none;
    }

    /* Glass Inputs */
    .glass-input {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        padding: 12px 16px 12px 42px;
        /* Left padding makes room for icon */
        border-radius: 12px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        height: 48px;
        /* Fixed height for alignment */
    }

    .glass-input:focus {
        background: rgba(0, 0, 0, 0.4);
        border-color: #667eea;
        box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.15);
        color: #fff;
    }

    .glass-input::placeholder {
        color: rgba(255, 255, 255, 0.4);
    }

    /* Fix for Select Dropdown Arrow Color in Dark Mode */
    .glass-input option {
        background-color: #1a1a2e;
        color: #fff;
    }

    /* Focus State for Icon */
    .glass-input:focus+.input-icon-left,
    .input-group-custom:focus-within .input-icon-left {
        color: #667eea;
    }

    /* Add Button Gradient */
    .btn-gradient-add {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 12px;
        color: white;
        font-weight: 600;
        height: 48px;
        /* Match input height */
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .btn-gradient-add:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        color: white;
    }

    .btn-gradient-add:active {
        transform: translateY(0);
    }

    /* Mobile Adjustments */
    @media (max-width: 768px) {
        .glass-command-bar {
            padding: 1rem;
        }

        .col-md-12 {
            margin-bottom: 0.5rem;
        }

        .btn-gradient-add {
            margin-top: 0.5rem;
        }
    }
</style>